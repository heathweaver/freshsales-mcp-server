# Required: Your Freshsales API key
# Get this from: Freshsales > Settings > API Settings
FRESHSALES_API_KEY=your_api_key_here

# Required: Your Freshworks subdomain (e.g. "acme" for acme.myfreshworks.com)
FRESHSALES_SUBDOMAIN=your_subdomain_here

# OAuth / MCP Auth
ISSUER_URL=https://freshsales.ssc.one
MCP_ALLOWED_TOKENS=test-token-12345

# Optional: MCP OAuth client credentials
# MCP_CLIENT_ID=freshsales-mcp-xxxx
# MCP_CLIENT_SECRET=xxxx

# Server
PORT=8768
HOST=0.0.0.0
DATA_DIR=/app/data
