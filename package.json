{
  "name": "@heathweaver/freshsales-mcp-server-http",
  "version": "0.1.0",
  "description": "HTTP-based Freshsales CRM MCP Server with Docker deployment and OAuth authentication.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "mcp-server-freshsales": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "build:check": "tsc --noEmit",
    "lint": "echo 'No linter configured'",
    "pretest": "npm run build",
    "test": "node --test tests/**/*.test.js",
    "test:watch": "node --test --watch tests/**/*.test.js",
    "prebuild": "npm run build:check",
    "prepack": "npm run build:check && npm test",
    "docker:build": "npm run build:check && npm test && npm run build && docker build -t freshsales-mcp-server-http .",
    "docker:build:fast": "npm run build && docker build -t freshsales-mcp-server-http ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heathweaver/freshsales-mcp-server.git"
  },
  "keywords": [
    "mcp",
    "freshsales",
    "freshworks",
    "crm",
    "claude",
    "ai",
    "modelcontextprotocol"
  ],
  "author": "Heath Weaver",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/heathweaver/freshsales-mcp-server/issues"
  },
  "homepage": "https://github.com/heathweaver/freshsales-mcp-server#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "dotenv": "^17.2.3",
    "shx": "^0.3.4",
    "typescript": "^5.7.2"
  }
}
